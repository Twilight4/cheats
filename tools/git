Common Commands:
  git init                            # Initialize git repo
  git status                          # status of changes
  git add *                           # add all files
  git commit -m "message"             # commit changes
  git remote add origin <git@github.com:name/repo.git>      # Set a new repo
  git branch -M main                  # set default branch to main
  git push -u origin <branch_name ex. master>              # push changes to branch master
  git pull -u origin <branch_name ex. master> <or_URL>     # pull changes from remote to master branch
  git diff <commit_id_1> <commit_id_2>     # View changes of the commit
  git retrieve <commit_id>           # revert a commit to a previous version (git log)
  git checkout <commit_id>           # open the commit version
  git log                             # view log changes

Branching:
  git branch                          # List branches
  git branch <new_of_new_branch>      # Create a new branch
  git branch -D <branch_name>         # Delete branch
  git checkout <branch_name>          # Switch to other branch
  git checkout -b <branch_name>       # Switch and create a new branch

Restore:
  git restore <path-to-file>          # Restore/revert the change of the deleted/changed file 
  git restore .                       # Restore all deleted/untracked changes
  git reset --soft HEAD~1             # Undo the last commit but keep the changes
  git reset --hard HEAD~1             # Undo the last commit and discard deletion (restore the files)
  git restore --source=<commit-hash> <file-path>       # restore a specific deleted file from the previous commit

Stash:
  git stash                           # Save changes (tracked files) to a new stash
  git stash push -m 'message' src/config.js     # Stash a specific file with a message
  git stash -u                        # Save changes including untracked files
  git stash -a                        # Save all changes including ignored files
  git stash list                      # List all stashes
  git stash show                      # Show summary of most recent stash
  git stash show -p                   # Show full diff of most recent stash
  git stash apply                     # Apply most recent stash without removing it
  git stash pop                       # Apply and remove the most recent stash
  git stash drop                      # Delete most recent stash
  git stash clear                     # Remove all stashes
  git stash branch <branch_name>      # Create new branch from a stash and apply it
  git stash push -m "message"         # Save stash with a custom message

Config:
  git config set webflyx.ceo "ThePrimeagen"      # set a custom config key (section.key) to a value
  git config set webflyx.cto "TheLaneagen"       # set another key in the same custom section
  git config list --local                         # list all config entries scoped to this repo only
  cat .git/config                                 # directly view the raw local config file
  git config get <key>                            # read the value of a specific key
  git config unset <key>                          # delete a key from config
  git config set --append webflyx.ceo "Warren"   # add a second value to the same key (multi-value)
  git config unset --all example.key             # remove all values for a multi-value key
  git config remove-section <section>            # remove an entire section from your Git configuration

